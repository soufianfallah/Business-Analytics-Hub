# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PostgreSQL (pooled runtime connection and direct migration connection)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/business_analytics_hub?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/business_analytics_hub?schema=public"

# Better Auth: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"

# SMTP delivery for verification, password-reset, and invitation messages
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="replace-me"
SMTP_PASSWORD="replace-me"
EMAIL_FROM="Business Analytics Hub <no-reply@example.com>"
# Set false only for isolated testing when no email provider is configured.
EMAIL_DELIVERY_ENABLED="true"

# Raw file storage. Use a durable mounted volume in production.
UPLOAD_DIR=".data/uploads"

# Protect the scheduled-report worker endpoint. Configure your cron provider to
# POST /api/jobs/reports with Authorization: Bearer <CRON_SECRET>.
CRON_SECRET="replace-with-a-long-random-secret"

# Local AI insights (no paid API)
AI_PROVIDER="ollama"
OLLAMA_MODEL="llama3.2"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
AI_TIMEOUT_MS="60000"
AI_MAX_RETRIES="2"
AI_CACHE_TTL_SECONDS="3600"

# Development and automated tests only. MockProvider is blocked in production.
MOCK_AI_RESPONSE="Deterministic mock response."

# Stripe test mode only. Leave blank to keep the free-plan design without billing.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""

# Bootstrap only: comma-separated accounts allowed to access /admin.
# Promote administrators in the Admin Dashboard, then this can be left empty.
PLATFORM_ADMIN_EMAILS=""

# Optional free/self-hosted Redis. The application falls back safely when absent.
REDIS_URL="redis://127.0.0.1:6379"

# Observability. Sentry is disabled when its DSN is empty.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_ORG=""
SENTRY_PROJECT=""
# Build/CI only; never expose this token to the browser.
SENTRY_AUTH_TOKEN=""
LOG_LEVEL="info"

# Docker Compose only. Replace these before exposing the stack publicly.
POSTGRES_DB="business_analytics_hub"
POSTGRES_USER="analytics"
POSTGRES_PASSWORD="replace-with-a-strong-password"
APP_PORT="3000"
